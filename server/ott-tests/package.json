{
  "name": "ott-platform-tests",
  "version": "1.0.0",
  "description": "Jest + Supertest automated tests for OTT Platform",
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles --runInBand",
    "test:verbose": "jest --forceExit --detectOpenHandles --runInBand --verbose",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --runInBand",
    "test:report": "jest --forceExit --detectOpenHandles --runInBand --json --outputFile=reports/test-results.json && node generate-report.js",
    "test:ci": "jest --forceExit --detectOpenHandles --runInBand --coverage --json --outputFile=reports/test-results.json && node generate-report.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testSequencer": "./testSequencer.js",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {}
      ]
    },
    "coverageDirectory": "reports/coverage",
    "coverageReporters": [
      "text",
      "json",
      "html"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "reporters": [
      "default",
      [
        "jest-html-reporter",
        {
          "pageTitle": "OTT Platform API Test Report",
          "outputPath": "reports/test-report.html",
          "includeFailureMsg": true,
          "includeConsoleLog": true,
          "theme": "darkTheme"
        }
      ]
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^16.6.1"
  }
}
